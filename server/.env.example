DATABASE_URL=postgresql://pos:pos@localhost:5432/pos
JWT_SECRET=change-me-in-production
PORT=3080
PRINTER_IP=192.168.0.107
PRINTER_PORT=9100
PORTOS_ENABLED=false
# PORTOS_BASE_URL:
# - `node server.js` na tom istom PC ako Portos: http://localhost:3010
# - Docker: hodnotu nastavuje docker-compose.yml (predvolené http://host.docker.internal:3010 = Portos na hostiteľovi
#   Windows/Mac). Kľúč PORTOS_BASE_URL v tomto súbore v kontajneri compose PREPÍŠE — na zmenu URL pre Docker
#   použi súbor `.env` v koreni repozitára (vedľa docker-compose.yml), napr. PORTOS_BASE_URL=http://192.168.0.15:3010
#   ak je Portos na inom stroji alebo host.docker.internal nefunguje.
PORTOS_BASE_URL=http://localhost:3010
PORTOS_CASH_REGISTER_CODE=88812345678900001
# Nie nazov zariadenia vo Windows! API NineDigit: pos = papier/CHDU, pdf, email
PORTOS_PRINTER_NAME=pos
PORTOS_TIMEOUT_MS=10000
