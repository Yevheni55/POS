DATABASE_URL=postgresql://pos:pos@localhost:5432/pos
JWT_SECRET=change-me-in-production
PORT=3000
PRINTER_IP=192.168.0.107
PRINTER_PORT=9100
PORTOS_ENABLED=false
# Pri spustení cez `docker compose` nastavuje compose PORTOS_BASE_URL na host.docker.internal:3010.
# Pri `node server.js` priamo na PC kde beží Portos: http://localhost:3010
PORTOS_BASE_URL=http://localhost:3010
PORTOS_CASH_REGISTER_CODE=88812345678900001
# Nie nazov zariadenia vo Windows! API NineDigit: pos = papier/CHDU, pdf, email
PORTOS_PRINTER_NAME=pos
PORTOS_TIMEOUT_MS=10000
