<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Základná XML téma (manifest). Compose si rieši farby cez SurfSpiritTheme;
         tu len NoActionBar + cream pozadie/lišty aby splash a okná ladili. -->
    <style name="Theme.SurfSpiritPOS" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/cream</item>
        <item name="android:statusBarColor">@color/cream</item>
        <item name="android:navigationBarColor">@color/cream</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
